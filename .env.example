DATABASE_URL=postgresql://rag:rag@localhost:5432/rag

# LM Studio runs an OpenAI-compatible server, default port 1234
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio

# Load this embedding model in LM Studio (768-dim).
# Swap for any embedding model you have loaded; update EMBEDDING_DIM to match.
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
EMBEDDING_DIM=768

CHAT_MODEL=openai/gpt-oss-20b

CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=5
